# URL del backend Python (FastAPI)
# En desarrollo local:
VITE_API_URL=http://localhost:8000

# En producción (Railway/Render):
# VITE_API_URL=https://tu-backend.railway.app

# Token de admin (debe coincidir con ADMIN_SECRET del backend)
